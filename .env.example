# Internal IA provider split. In this phase both default to Gemini-backed behavior.
# The next phase will switch text generation to a local provider.
TEXT_AI_PROVIDER=gemini
IMAGE_AI_PROVIDER=gemini

# Optional for real Gemini generation. Create your own key in Google AI Studio.
# Leave empty to use the documented local fallback. Do not commit .env or any real API key.
GEMINI_API_KEY=

# Current stable lite model used by the backend.
GEMINI_MODEL=gemini-2.5-flash-lite

# Enables Gemini Google Search grounding for on-demand recipe image lookup.
GEMINI_ENABLE_GOOGLE_SEARCH=true
