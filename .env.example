# Internal IA provider split. Text now defaults to a local Ollama provider.
TEXT_AI_PROVIDER=ollama
IMAGE_AI_PROVIDER=gemini
LOCAL_TEXT_BASE_URL=http://localhost:11434
LOCAL_TEXT_MODEL=qwen2.5:1.5b

# Optional for real Gemini generation. Create your own key in Google AI Studio.
# Leave empty if you only want local text generation and do not need recipe image resolution.
# Do not commit .env or any real API key.
GEMINI_API_KEY=

# Current stable lite model used by the backend.
GEMINI_MODEL=gemini-2.5-flash-lite

# Enables Gemini Google Search grounding for on-demand recipe image lookup.
GEMINI_ENABLE_GOOGLE_SEARCH=true
